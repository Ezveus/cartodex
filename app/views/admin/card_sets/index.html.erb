<div class="admin-container">
  <div class="admin-header">
    <h1>Card Sets</h1>
    <%= link_to "New Set", new_admin_card_set_path, class: "btn btn-primary" %>
  </div>

  <table class="admin-table">
    <thead>
      <tr>
        <th>Code</th>
        <th>Name</th>
        <th>Block</th>
        <th>Release Date</th>
        <th>Cards</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @card_sets.each do |card_set| %>
        <tr>
          <td><%= card_set.code %></td>
          <td><%= link_to card_set.name, admin_card_set_path(card_set) %></td>
          <td><%= card_set.block_name %></td>
          <td><%= card_set.release_date&.strftime("%Y-%m-%d") %></td>
          <td><%= card_set.cards.size %></td>
          <td>
            <%= link_to "Edit", edit_admin_card_set_path(card_set), class: "btn btn-secondary btn-sm" %>
            <%= link_to "Delete", admin_card_set_path(card_set), data: { turbo_method: :delete, turbo_confirm: "Delete #{card_set.name}?" }, class: "btn-danger" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
