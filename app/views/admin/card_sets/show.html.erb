<div class="admin-container">
  <div class="admin-header">
    <div>
      <h1><%= @card_set.name %> (<%= @card_set.code %>)</h1>
      <p>Block: <strong><%= @card_set.block_name %></strong> — Released: <strong><%= @card_set.release_date&.strftime("%Y-%m-%d") || "N/A" %></strong></p>
    </div>
    <%= link_to "Edit", edit_admin_card_set_path(@card_set), class: "btn btn-secondary" %>
  </div>

  <h2>Cards (<%= @cards.size %>)</h2>
  <table class="admin-table">
    <thead>
      <tr><th>#</th><th>Name</th><th>Type</th><th>HP</th><th>Rarity</th></tr>
    </thead>
    <tbody>
      <% @cards.each do |card| %>
        <tr>
          <td><%= card.set_number %></td>
          <td><%= link_to card.name, admin_card_path(card) %></td>
          <td><%= card.card_type %></td>
          <td><%= card.hp %></td>
          <td><%= card.rarity %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
