<div class="admin-container">
  <h1>Dashboard</h1>

  <div class="admin-stats-grid">
    <div class="admin-stat-card">
      <div class="admin-stat-value"><%= @user_count %></div>
      <div class="admin-stat-label">Users</div>
    </div>
    <div class="admin-stat-card">
      <div class="admin-stat-value"><%= @card_count %></div>
      <div class="admin-stat-label">Cards</div>
    </div>
    <div class="admin-stat-card">
      <div class="admin-stat-value"><%= @set_count %></div>
      <div class="admin-stat-label">Sets</div>
    </div>
    <div class="admin-stat-card">
      <div class="admin-stat-value"><%= @deck_count %></div>
      <div class="admin-stat-label">Decks</div>
    </div>
  </div>

  <div class="admin-grid-2col">
    <div>
      <h2>Recent Users</h2>
      <table class="admin-table">
        <thead>
          <tr><th>Email</th><th>Admin</th><th>Joined</th></tr>
        </thead>
        <tbody>
          <% @recent_users.each do |user| %>
            <tr>
              <td><%= user.email %></td>
              <td><%= user.admin? ? "Yes" : "No" %></td>
              <td><%= user.created_at.strftime("%Y-%m-%d") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div>
      <h2>Recent Decks</h2>
      <table class="admin-table">
        <thead>
          <tr><th>Name</th><th>Owner</th><th>Created</th></tr>
        </thead>
        <tbody>
          <% @recent_decks.each do |deck| %>
            <tr>
              <td><%= link_to deck.name, admin_deck_path(deck) %></td>
              <td><%= deck.user.email %></td>
              <td><%= deck.created_at.strftime("%Y-%m-%d") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
