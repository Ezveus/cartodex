<div class="admin-container">
  <div class="admin-header">
    <div>
      <h1><%= @deck.name %></h1>
      <p>Owner: <strong><%= @deck.user.email %></strong> — Cards: <strong><%= @deck.deck_cards.sum(&:quantity) %></strong></p>
    </div>
    <%= link_to "Back", admin_decks_path, class: "btn btn-secondary" %>
  </div>

  <% card_groups = @deck.deck_cards.group_by { |dc| dc.card.card_type } %>
  <% %w[Pokémon Trainer Energy].each do |type| %>
    <% group = card_groups[type] %>
    <% next unless group.present? %>
    <h2><%= type %> (<%= group.sum(&:quantity) %>)</h2>
    <table class="admin-table">
      <thead>
        <tr><th>Qty</th><th>Name</th><th>Set</th></tr>
      </thead>
      <tbody>
        <% group.sort_by { |dc| dc.card.name }.each do |dc| %>
          <tr>
            <td><%= dc.quantity %></td>
            <td><%= link_to dc.card.name, admin_card_path(dc.card) %></td>
            <td><%= dc.card.set_name %> <%= dc.card.set_number %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
