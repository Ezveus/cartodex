<div class="cards-container">
  <h1>Cards</h1>

  <div class="cards-layout">
    <nav class="sets-sidebar">
      <% @blocks.each do |block_name, sets| %>
        <div class="sets-block">
          <h3 class="sets-block-name"><%= block_name %></h3>
          <ul class="sets-list">
            <% sets.each do |card_set| %>
              <%= content_tag :li, class: ("active" if @current_set == card_set) do %>
                <%= link_to cards_path(set: card_set.code) do %>
                  <span class="set-full-name"><%= card_set.name %></span>
                  <span class="set-code"><%= card_set.code %> (<%= card_set.cards.size %>)</span>
                <% end %>
              <% end %>
            <% end %>
          </ul>
        </div>
      <% end %>
    </nav>

    <div class="cards-grid-area">
      <% if @current_set %>
        <h2><%= @current_set.name %></h2>
        <div class="cards-grid">
          <% @cards.each do |card| %>
            <%= link_to card_path(card), class: "card-grid-item" do %>
              <% if card.image_url.present? %>
                <%= image_tag card.image_url, alt: card.name, class: "card-grid-image", loading: "lazy" %>
              <% end %>
              <span class="card-grid-name"><%= card.name %></span>
              <span class="card-grid-number">#<%= card.set_number %></span>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="cards-empty">Select a set to browse cards.</p>
      <% end %>
    </div>
  </div>
</div>
