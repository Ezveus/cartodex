<div class="card-show-container">
  <div class="card-show-header">
    <h1><%= @card.name %></h1>
    <%= link_to "Back", :back, class: "btn btn-secondary" %>
  </div>

  <div class="card-show-content">
    <div class="card-show-image">
      <% if @card.image_url.present? %>
        <%= image_tag @card.image_url, alt: @card.name, class: "card-full-image" %>
      <% end %>
    </div>

    <div class="card-show-details">
      <div class="card-info-section">
        <h2>Info</h2>
        <dl class="card-info-list">
          <dt>Type</dt>
          <dd><%= @card.card_type %></dd>

          <% if @card.subtype.present? %>
            <dt>Subtype</dt>
            <dd><%= @card.subtype %></dd>
          <% end %>

          <% if @card.stage.present? %>
            <dt>Stage</dt>
            <dd><%= @card.stage %></dd>
          <% end %>

          <% if @card.hp.present? %>
            <dt>HP</dt>
            <dd><%= @card.hp %></dd>
          <% end %>

          <% if @card.type_symbol.present? %>
            <dt>Energy Type</dt>
            <dd><%= @card.type_symbol %></dd>
          <% end %>

          <% if @card.evolves_from.present? %>
            <dt>Evolves From</dt>
            <dd><%= @card.evolves_from %></dd>
          <% end %>

          <% if @card.weakness.present? %>
            <dt>Weakness</dt>
            <dd><%= @card.weakness %></dd>
          <% end %>

          <% if @card.resistance.present? %>
            <dt>Resistance</dt>
            <dd><%= @card.resistance %></dd>
          <% end %>

          <% if @card.retreat_cost.present? %>
            <dt>Retreat Cost</dt>
            <dd><%= @card.retreat_cost %></dd>
          <% end %>

          <dt>Set</dt>
          <dd><%= @card.set_full_name || @card.set_name %> (<%= @card.set_number %>)</dd>

          <% if @card.rarity.present? %>
            <dt>Rarity</dt>
            <dd><%= @card.rarity %></dd>
          <% end %>

          <% if @card.regulation_mark.present? %>
            <dt>Regulation</dt>
            <dd><%= @card.regulation_mark %></dd>
          <% end %>

          <% if @card.artist.present? %>
            <dt>Artist</dt>
            <dd><%= @card.artist %></dd>
          <% end %>

          <% if @card.price_eur.present? || @card.price_usd.present? %>
            <dt>Price</dt>
            <dd>
              <%= number_to_currency(@card.price_eur, unit: "€") if @card.price_eur.present? %>
              <%= " / " if @card.price_eur.present? && @card.price_usd.present? %>
              <%= number_to_currency(@card.price_usd, unit: "$") if @card.price_usd.present? %>
            </dd>
          <% end %>
        </dl>
      </div>

      <% if @card.abilities.any? %>
        <div class="card-info-section">
          <h2>Abilities</h2>
          <% @card.abilities.each do |ability| %>
            <div class="card-move">
              <strong><%= ability.name %></strong>
              <% if ability.effect.present? %>
                <p><%= ability.effect %></p>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

      <% if @card.attacks.any? %>
        <div class="card-info-section">
          <h2>Attacks</h2>
          <% @card.attacks.each do |attack| %>
            <div class="card-move">
              <div class="card-move-header">
                <strong><%= attack.name %></strong>
                <% if attack.cost.present? %>
                  <span class="card-move-cost"><%= attack.cost %></span>
                <% end %>
                <% if attack.damage.present? %>
                  <span class="card-move-damage"><%= attack.damage %></span>
                <% end %>
              </div>
              <% if attack.effect.present? %>
                <p><%= attack.effect %></p>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

      <% if @card.effect.present? %>
        <div class="card-info-section">
          <h2>Effect</h2>
          <p><%= @card.effect %></p>
        </div>
      <% end %>

      <% if @alt_printings.any? %>
        <div class="card-info-section">
          <h2>Alternative Printings</h2>
          <div class="alt-printings">
            <% @alt_printings.each do |alt| %>
              <%= link_to card_path(alt), class: "alt-printing-item" do %>
                <% if alt.image_url.present? %>
                  <%= image_tag alt.image_url, alt: alt.name, class: "alt-printing-image" %>
                <% end %>
                <span class="alt-printing-set"><%= alt.set_full_name || alt.set_name %> (<%= alt.set_number %>)</span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
