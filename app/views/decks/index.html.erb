<div class="decks-container">
  <div class="decks-header">
    <h1>My Decks</h1>
    <div class="decks-header-actions">
      <%= link_to "New Deck", new_deck_path, class: "btn btn-primary" %>
    </div>
  </div>

  <% if @decks.any? %>
    <div class="decks-grid">
      <% @decks.each do |deck| %>
        <%= link_to deck_path(deck), class: "deck-item" do %>
          <h2><%= deck.name %></h2>
          <% if deck.description.present? %>
            <p class="deck-description"><%= deck.description %></p>
          <% end %>
          <p class="deck-card-count"><%= deck.deck_cards.sum(&:quantity) %> cards</p>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p>No decks yet. <%= link_to "Import one from the dashboard", dashboard_path %>.</p>
  <% end %>
</div>
