<div class="deck-show-container" data-controller="card-preview">
  <div class="deck-show-header">
    <div>
      <h1><%= @deck.name %></h1>
      <% if @deck.description.present? %>
        <p class="deck-show-description"><%= @deck.description %></p>
      <% end %>
    </div>
    <%= link_to "Back to Decks", decks_path, class: "btn btn-secondary" %>
  </div>

  <div class="deck-show-stats">
    <div class="stat">
      <span class="stat-value"><%= @deck.deck_cards.sum(&:quantity) %></span>
      <span class="stat-label">cards</span>
    </div>
    <% wins = @deck.deck_results.count { |r| r.result == "win" } %>
    <% losses = @deck.deck_results.count { |r| r.result == "loss" } %>
    <div class="stat">
      <span class="stat-value"><%= wins %></span>
      <span class="stat-label">wins</span>
    </div>
    <div class="stat">
      <span class="stat-value"><%= losses %></span>
      <span class="stat-label">losses</span>
    </div>
  </div>

  <div class="deck-show-content">
    <div class="deck-show-main">
      <div class="deck-card-search" data-controller="card-search" data-card-search-deck-id-value="<%= @deck.id %>">
        <input type="text"
               placeholder="Search cards to add..."
               data-card-search-target="input"
               data-action="input->card-search#search"
               class="form-input card-search-input" />
        <div data-card-search-target="results" class="card-search-results"></div>
      </div>

      <% card_groups = @deck.deck_cards.group_by { |dc| dc.card.card_type } %>
      <% %w[Pokémon Trainer Energy].each do |type| %>
        <% group = card_groups[type] %>
        <% next unless group.present? %>
        <div class="deck-section">
          <h2><%= type %> (<%= group.sum(&:quantity) %>)</h2>
          <ul class="deck-card-list">
            <% group.sort_by { |dc| dc.card.name }.each do |dc| %>
              <li class="deck-card-item"
                  data-card-preview-url="<%= dc.card.image_url %>"
                  data-card-preview-card-id="<%= dc.card.id %>"
                  data-action="mouseenter->card-preview#show"
                  data-controller="deck-card-quantity"
                  data-deck-card-quantity-deck-id-value="<%= @deck.id %>"
                  data-deck-card-quantity-card-id-value="<%= dc.card.id %>"
                  data-deck-card-quantity-quantity-value="<%= dc.quantity %>">
                <div class="deck-card-qty-controls">
                  <button class="qty-btn" data-action="deck-card-quantity#decrement">-</button>
                  <span class="deck-card-qty"><%= dc.quantity %></span>
                  <button class="qty-btn" data-action="deck-card-quantity#increment">+</button>
                </div>
                <span class="deck-card-name"><%= dc.card.name %></span>
                <span class="deck-card-set"><%= dc.card.set_name %> <%= dc.card.set_number %></span>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>

    <div class="deck-show-preview">
      <%= image_tag "", data: { card_preview_target: "image" }, class: "card-preview-image", style: "display: none" %>
      <%= link_to "View card details", "#", data: { card_preview_target: "link" }, class: "card-preview-link", style: "display: none" %>
    </div>
  </div>
</div>
