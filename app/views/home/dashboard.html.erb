<div class="dashboard-container" data-controller="decks">
  <h1>Welcome, <%= current_user.email %></h1>

  <div class="dashboard-grid">
    <div class="dashboard-card" data-controller="collection">
      <h2>My Collection</h2>
      <div class="card-count">
        <span data-collection-target="count">0</span> cards
      </div>
      <div class="card-actions">
        <%= link_to "View Collection", "#", class: "btn btn-primary", data: { action: "collection#view" } %>
        <%= link_to "Scan Card", "#", class: "btn btn-secondary", data: { action: "collection#openScanner" } %>
      </div>
    </div>

    <div class="dashboard-card">
      <h2>My Decks</h2>
      <div class="deck-count">
        <span id="deck-count" data-decks-target="count">0</span> decks
      </div>
      <div class="deck-actions">
        <%= link_to "View Decks", decks_path, class: "btn btn-primary" %>
        <%= link_to "Create Deck", "#", class: "btn btn-secondary", data: { action: "decks#create" } %>
        <%= link_to "Import Deck", "#", class: "btn btn-secondary", data: { action: "decks#openImport" } %>
      </div>
      <div class="importing-section" style="display: none;" data-controller="importing-list">
        <h3>Importing…</h3>
        <ul id="importing-decks" data-decks-target="importingList" data-importing-list-target="list" class="importing-list"></ul>
      </div>
    </div>
  </div>

  <div id="import-modal" class="modal" data-decks-target="importModal">
    <div class="modal-content">
      <h2>Import Deck</h2>
      <div class="form-group">
        <label class="form-label" for="import-deck-name">Deck name</label>
        <input type="text" id="import-deck-name" class="form-input" data-decks-target="importName" placeholder="My Deck">
      </div>
      <div class="form-group">
        <label class="form-label" for="import-decklist">Decklist</label>
        <textarea id="import-decklist" class="form-input" data-decks-target="importDecklist" rows="10" placeholder="4 Comfey LOR 79&#10;2 Giratina VSTAR LOR 131&#10;..."></textarea>
      </div>
      <div class="form-actions import-actions">
        <button class="btn btn-primary" data-action="decks#submitImport" data-decks-target="importSubmit">Import</button>
        <button class="btn btn-secondary" data-action="decks#closeImport">Cancel</button>
      </div>
    </div>
  </div>

  <div id="scanner-modal" class="modal" data-collection-target="scannerModal">
    <div class="modal-content">
      <h2>Scan Card</h2>
      <video id="scanner-video" data-collection-target="video"></video>
      <button class="btn btn-secondary" data-action="collection#closeScanner">Close</button>
    </div>
  </div>
</div>
