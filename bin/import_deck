#!/usr/bin/env ruby
require_relative "../config/environment"

usage = <<~USAGE
  Usage: bin/import_deck DECK_NAME [FILE]

  Import a decklist and fetch all cards from Limitless TCG.

  DECK_NAME  Name for the deck (required)
  FILE       Path to a decklist file (reads from stdin if omitted)

  Examples:
    bin/import_deck "Doublade Dudunsparce" decklist.txt
    cat decklist.txt | bin/import_deck "Doublade Dudunsparce"
    pbpaste | bin/import_deck "Doublade Dudunsparce"
USAGE

deck_name = ARGV[0]
if deck_name.nil? || deck_name.start_with?("-")
  puts usage
  exit 1
end

file_path = ARGV[1]
decklist = if file_path
  abort "File not found: #{file_path}" unless File.exist?(file_path)
  File.read(file_path)
else
  $stdin.read
end

abort "Empty decklist" if decklist.strip.empty?

user = User.first
abort "No user found. Create a user first." unless user

puts "Importing deck \"#{deck_name}\"..."
deck = Decks::Fetcher.call(decklist, user, deck_name)
puts "Done! Deck \"#{deck.name}\" created with #{deck.deck_cards.count} cards."
